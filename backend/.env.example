# Nest backend environment template.
# Copy to backend/.env for local dev, or set the same keys under
# Render -> Service -> Environment for production.

# --- Required for /chat (LLM provider) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Optional overrides ---
# Groq model name. See https://console.groq.com/docs/models
MODEL_NAME=llama-3.3-70b-versatile

# HuggingFace embedding model used by Chroma during ingest + retrieval.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Comma-separated list of allowed origins for CORS, or "*" for any.
# Example for production:
# CORS_ORIGINS=https://nest-frontend.onrender.com,https://nest.kennesaw.edu
CORS_ORIGINS=http://localhost:5173

# Where the persisted Chroma collection lives. Relative paths resolve
# against the backend/ directory. On Render this should point inside
# the service's persistent disk (e.g. /var/data/vectorstore).
CHROMA_DIR=vectorstore
CHROMA_COLLECTION=nest_resources

# JSON resource catalog ingested by rag/ingest.py.
RESOURCE_DB_PATH=data/georgia_resources.json

# "development" or "production". Only used for log/diagnostic context today.
ENVIRONMENT=development
